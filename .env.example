# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Maps JavaScript API key for the in-app location picker.
# Restrict the key to your website domain in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_API_KEY"

# GOOGLE CLIENT CREDENTIALS: Required for real Google Account Login.
# Users configure these via the Secrets panel in the AI Studio UI.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# --- REAL SMS OTP GATEWAYS CONFIGURATION ---

# Option A: SpeedSMS.vn (Vietnamese CSKH / OTP SMS service)
SPEEDSMS_API_KEY="MY_SPEEDSMS_API_KEY"
SPEEDSMS_SENDER="MY_SPEEDSMS_SENDER"
SPEEDSMS_TYPE="2"

# Option B: eSMS.vn (Vietnamese local SMS Brandname & OTP service)
ESMS_API_KEY="MY_ESMS_API_KEY"
ESMS_SECRET_KEY="MY_ESMS_SECRET_KEY"
ESMS_SMS_TYPE="8"
ESMS_BRANDNAME="Baotinnho"

# Option C: Twilio SMS (Global SMS gateway)
TWILIO_ACCOUNT_SID="MY_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="MY_TWILIO_AUTH_TOKEN"
TWILIO_PHONE_NUMBER="MY_TWILIO_PHONE_NUMBER"

# Option D: Telegram Bot Fallback (Free & near-instant testing option)
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="MY_TELEGRAM_CHAT_ID"
